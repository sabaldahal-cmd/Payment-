{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and wallet data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "biometricEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["INCOME", "EXPENSE"] },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "timestamp": { "type": "number" },
        "recipient": { "type": "string" },
        "sender": { "type": "string" }
      },
      "required": ["userId", "amount", "type", "title", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction logs"
    }
  }
}
